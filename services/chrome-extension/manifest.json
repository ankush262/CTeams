{
  "manifest_version": 3,
  "name": "Meeting Intelligence Companion",
  "version": "2.0.0",
  "description": "Real-time transcription, action tracking, and live meeting debrief companion.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://*.teams.microsoft.com/*",
    "http://localhost:8000/*",
    "ws://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meeting Intelligence Companion"
  }
}
