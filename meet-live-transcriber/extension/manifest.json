{
  "manifest_version": 3,
  "name": "Meet Live Transcriber",
  "version": "1.1.0",
  "description": "Real-time speech-to-text transcription overlay for Google Meet.",

  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "offscreen",
    "storage"
  ],

  "host_permissions": [
    "https://meet.google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Live Transcriber"
  }
}
